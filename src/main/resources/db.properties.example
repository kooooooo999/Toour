# 데이터베이스 연결 정보
# 이 파일을 db.properties로 복사한 후 실제 값을 입력하세요.

# 데이터베이스 URL
db.url=jdbc:mysql://YOUR_DB_HOST:3306/YOUR_DB_NAME?useUnicode=true&characterEncoding=UTF-8

# 데이터베이스 사용자명
db.username=YOUR_DB_USERNAME

# 데이터베이스 비밀번호
db.password=YOUR_DB_PASSWORD

# 데이터베이스 드라이버
db.driver=com.mysql.cj.jdbc.Driver

