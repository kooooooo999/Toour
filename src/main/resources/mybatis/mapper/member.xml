<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="member">
    <resultMap id="map1" type="toour.member.vo.MemberVO">
        <id property="member_idx" column="member_idx"/>
        <collection property="zzimlist" ofType="toour.member.vo.ZzimVO" select="zzim.get" column="member_idx"/>
    </resultMap>

    <!--아이디로 회원 정보 받기-->
    <select id="get" parameterType="String" resultMap="map1">
        SELECT * FROM member
        WHERE member_id = #{member_id}
    </select>

    <!-- 닉네임으로 회원 정보 받기 -->
    <select id="getN" parameterType="String" resultType="toour.member.vo.MemberVO">
        SELECT * FROM member
        WHERE member_nickname = #{nickname}
    </select>

    <!-- 이메일로 회원 정보 받기 -->
    <select id="getE" parameterType="String" resultType="toour.member.vo.MemberVO">
        SELECT * FROM member
        WHERE member_email = #{email}
    </select>

    <!--회원가입-->
    <insert id="add" parameterType="toour.member.vo.MemberVO">
        INSERT INTO member ( member_name, member_nickname, member_password, member_email, member_created_at, member_updated_at, member_salt, member_id)
        VALUES (#{member_name}, #{member_nickname}, #{member_password}, #{member_email}, NOW(), NOW(), #{member_salt}, #{member_id})
    </insert>

</mapper>