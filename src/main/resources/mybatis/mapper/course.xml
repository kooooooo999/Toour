<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="course">

    <resultMap id="Map2" type="toour.member.vo.CourseDateVO">
        <id property="courseDate_idx" column="courseDate_idx"/>
        <collection property="courseIn_list" ofType="toour.member.vo.CourseInVO" select="course.getCourseIn" column="courseDate_idx"/>
    </resultMap>

    <resultMap id="Map1" type="toour.member.vo.CourseVO">
        <id property="course_idx" column="course_idx"/>
        <collection property="courseDate_list" ofType="toour.member.vo.CourseDateVO" select="course.getCourseDate" column="course_idx"/>
    </resultMap>

    <select id="get" parameterType="String" resultMap="Map1">
        SELECT * FROM course
        WHERE member_idx = #{member_idx}
    </select>

    <select id="getCourseDate" parameterType="String" resultMap="Map2">
        SELECT * FROM courseDate
        WHERE course_idx = #{course_idx}
    </select>

    <select id="getCourseIn" parameterType="String" resultType="toour.member.vo.CourseInVO">
        SELECT * FROM courseIn
        WHERE courseDate_idx = #{courseDate_idx}
    </select>

    <insert id="addCourse" parameterType="Map">
        insert into course ( member_idx, course_name, created_at, course_summary )
        values ( #{member_idx}, #{course_name}, now(), #{course_summary} )
    </insert>

    <insert id="courseDateAdd" parameterType="Map" useGeneratedKeys="true" keyProperty="courseDate_idx">
        insert into courseDate ( date, course_idx, date_title )
        values ( #{date}, #{course_idx}, #{date_title} )
    </insert>

    <insert id="courseInAdd" parameterType="toour.member.vo.CourseInVO">
        insert into courseIn ( courseDate_idx, contentId, contentTypeId, title, addr1, mapx, mapy )
        values ( #{courseDate_idx}, #{contentId}, #{contentTypeId}, #{title}, #{addr1}, #{mapx}, #{mapy} )
    </insert>

    <update id="courseEdit" parameterType="Map">
        UPDATE courseIn
        <trim prefix="SET" suffixOverrides=",">
            contentId = #{contentId},
            contentTypeId = #{contentTypeId},
            title = #{title},
            addr1 = #{addr1},
            mapx = #{mapx},
            mapy = #{mapy}
        </trim>
        WHERE courseDate_idx = #{courseDate_idx}
    </update>

</mapper>